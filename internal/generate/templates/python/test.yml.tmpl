name: Test

on:
  workflow_call:

concurrency:
  group: {{ gh "github.workflow" }}-{{ gh "github.ref" }}
  cancel-in-progress: false

jobs:
  test:
    name: Test
    runs-on: ubuntu-latest
    strategy:
      matrix:
        python-version: ['3.10', '3.11', '3.12']
    steps:
      - uses: actions/checkout@11bd71901bbe5b1630ceea73d27597364c9af683 # v4.2.2
      - uses: actions/setup-python@a26af69be951a213d495a4c3e4e4022e16d87065 # v5.6.0
        with:
          python-version: {{ gh "matrix.python-version" }}
          cache: '{{ if .UsePoetry}}poetry{{ else }}pip{{ end }}'
      - run: {{ if .UsePoetry }}pip install poetry && poetry install{{ else }}pip install -r requirements.txt{{ end }}
      - run: {{ if .UsePoetry }}poetry run pytest --cov{{ else }}pytest --cov{{ end }}
