name: Test

on:
  workflow_call:

jobs:
  test:
    name: Test
    runs-on: ubuntu-latest
    strategy:
      matrix:
        python-version: ['3.10', '3.11', '3.12']
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-python@v5
        with:
          python-version: {{ gh "matrix.python-version" }}
      - run: {{ if .UsePoetry }}pip install poetry && poetry install{{ else }}pip install -r requirements.txt{{ end }}
      - run: {{ if .UsePoetry }}poetry run pytest --cov{{ else }}pytest --cov{{ end }}
