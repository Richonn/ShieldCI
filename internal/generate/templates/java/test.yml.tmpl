name: Test

on:
  workflow_call:

concurrency:
  group: {{ gh "github.workflow" }}-{{ gh "github.ref" }}
  cancel-in-progress: false

jobs:
  test:
    name: Build & Test
    runs-on: ubuntu-latest
    strategy:
      matrix:
        java-version: ['21', '23']
    steps:
      - uses: actions/checkout@11bd71901bbe5b1630ceea73d27597364c9af683 # v4.2.2
      - uses: actions/setup-java@3a4f6e1af504cf6a31855fa899c6aa5355ba6c12 # v4.7.0
        with:
          java-version: {{ gh "matrix.java-version"}}
          distribution: 'temurin'
          cache: '{{ if .UseMaven }}maven{{ else }}gradle{{ end }}'
      - name: Build and test
        run: {{ if .UseMaven }}mvn --batch-mode verify{{ else }}./gradlew build{{ end }}
      - name: Upload coverage (JaCoCo)
        uses: actions/upload-artifact@ea165f8d65b6e75b540449e92b4886f43607fa02 # v4.6.2
        with:
          name: jacoco-report
          path: {{ if .UseMaven }}target/site/jacoco{{ else }}build/reports/jacoco{{ end }}
