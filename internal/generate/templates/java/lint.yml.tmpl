name: Lint

on:
  workflow_call:

jobs:
  lint:
    name: Lint
    runs-on: ubuntu-latest
    strategy:
      matrix:
        java-version: ['21', '23']
    steps:
      - uses: actions/checkout@11bd71901bbe5b1630ceea73d27597364c9af683 # v4.2.2
      - uses: actions/setup-java@3a4f6e1af504cf6a31855fa899c6aa5355ba6c12 # v4.7.0
        with:
          java-version: {{ gh "matrix.java-version"}}
          distribution: 'temurin'
          cache: '{{ if .UseMaven }}maven{{ else }}gradle{{ end }}'
      - name: Checkstyle
        run: {{ if .UseMaven }}mvn --batch-mode checkstyle:check{{ else }}./gradlew checkstyleMain{{ end }}
