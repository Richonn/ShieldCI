name: Docker - Build & Scan

on:
  workflow_call:
    outputs:
      digest:
        description: "Image digest"
        value: {{ gh "jobs.build-and-scan.outputs.digest" }}
      image:
        description: "Image name (lowercase)"
        value: {{ gh "jobs.build-and-scan.outputs.image" }}

permissions:
  contents: read
  security-events: write
  packages: write
  id-token: write

jobs:
  build-and-scan:
    name: Build & Trivy Scan
    runs-on: ubuntu-latest
    outputs:
      digest: {{ gh "steps.build.outputs.digest" }}
      image: {{ gh "steps.meta.outputs.image" }}
    steps:
      - uses: actions/checkout@11bd71901bbe5b1630ceea73d27597364c9af683 # v4.2.2

      - name: Set up Docker Buildx
        uses: docker/setup-buildx-action@b5ca514318bd6ebac0fb2aedd5d36ec1b5c232a2 # v3.10.0

      - name: Set image name
        id: meta
        run: echo "image=ghcr.io/$(echo '{{ gh "github.repository" }}' | tr '[:upper:]' '[:lower:]')" >> $GITHUB_OUTPUT

      - name: Connect to registry
        uses: docker/login-action@74a5d142397b4f367a81961eba4e8cd7edddf772 # v3.4.0
        with:
          registry: ghcr.io
          username: {{ gh "github.actor" }}
          password: {{ gh "secrets.GITHUB_TOKEN" }}

      - name: Build image
        id: build
        uses: docker/build-push-action@ca052bb54ab0790a636c9b5f226502c73d547a25 # v5.4.0
        with:
          context: .
          push: true
          platforms: linux/amd64,linux/arm64
          tags: {{ gh "steps.meta.outputs.image" }}:{{ gh "github.sha" }}
          cache-from: type=gha
          cache-to: type=gha,mode=max

{{ if .Stack.EnableTrivy -}}
      - name: Trivy vulnerability scan
        uses: aquasecurity/trivy-action@6c175e9c4083a92bbca2f9724c8a5e33bc2d97a5 # v0.30.0
        with:
          image-ref: '{{ gh "steps.meta.outputs.image" }}:{{ gh "github.sha" }}'
          format: sarif
          output: trivy-results.sarif
          severity: CRITICAL,HIGH
          ignore-unfixed: true

      - name: Upload trivy results to Security tab
        uses: github/codeql-action/upload-sarif@28deaeda66b76a05916b6923827895f2b14ab387 # v3.28.16
        if: always()
        with:
          sarif_file: trivy-results.sarif
{{ end -}}

      - name: Install Cosign
        uses: sigstore/cosign-installer@dc72c7d5c4d10cd6bcb8cf6e3fd625a9e5e537da # v3.7.0

      - name: Run Cosign
        run: cosign sign --yes {{ gh "steps.meta.outputs.image" }}:{{ gh "github.sha" }}
