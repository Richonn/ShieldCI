# Semgrep custom rules — generated by ShieldCI
#
# This file is a starting point. Add your own rules below.
# Full documentation: https://semgrep.dev/docs/writing-rules/overview
#
# To test your rules locally:
#   semgrep --config .semgrep/rules/ .

rules:
  - id: no-hardcoded-secrets
    patterns:
      - pattern: |
          $KEY = "..."
    metavariable-regex:
      metavariable: $KEY
      regex: '(?i)(password|secret|token|api_key|apikey)'
    message: |
      Possible hardcoded secret in variable '$KEY'.
      Use environment variables or a secrets manager instead.
    severity: ERROR
    languages: [{{ .Stack.Language }}]
